# Raspberry Pi Zero Configuration
Host pi-zero
    HostName 192.168.11.244
    User pi
    Port 22
    IdentityFile ~/.ssh/id_ed25519
    ServerAliveInterval 60
    ServerAliveCountMax 3
    StrictHostKeyChecking ask
    
# Shortcut for quick connection
Host piz
    HostName 192.168.11.244
    User pi
    Port 22
    IdentityFile ~/.ssh/id_ed25519
    ServerAliveInterval 60
    ServerAliveCountMax 3 